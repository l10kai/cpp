{
    "tasks": [
        {
            "type": "shell",
            "label": "g++ build",
            "command": "g++",
            "args": [
                "-std=c++20",
                //"-std=c++14",
                "-g",
                "${file}",
                "-o",
                "E:\\Cpp\\.exe\\${fileBasenameNoExtension}.exe",
                "-O2",
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}